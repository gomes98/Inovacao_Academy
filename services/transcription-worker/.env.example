# --- Supabase ---
SUPABASE_URL=https://meeljfafqdhtrmatizkm.supabase.co
# service_role key — NUNCA expor no front
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=courses

# --- Webhook ---
# Mesmo valor configurado no header Authorization do Database Webhook
WORKER_WEBHOOK_SECRET=trocar-isto
PORT=8787

# --- OpenAI (embeddings) ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- Whisper (sidecar Python) ---
# Caminho do Python (ou do binário do venv, ex: .venv/bin/python)
WHISPER_PYTHON=python
WHISPER_MODEL=large-v3
# cuda (GPU) ou cpu
WHISPER_DEVICE=cuda
# float16 para GPU, int8 para CPU
WHISPER_COMPUTE_TYPE=float16
# Idioma forcado, ex: pt — vazio = auto-detect
WHISPER_LANGUAGE=

# --- Chunking ---
CHUNK_TARGET_TOKENS=400
CHUNK_OVERLAP_TOKENS=60

# --- Fila ---
# Quantos videos em paralelo (1 e seguro para 1 GPU)
JOB_CONCURRENCY=1

# --- Logging ---
LOG_LEVEL=info
