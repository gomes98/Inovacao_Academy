{
  "name": "inovacao-academy-transcription-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Worker que transcreve vídeos via faster-whisper e gera embeddings para busca semântica no Inovação Academy.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.65.0",
    "p-queue": "^8.0.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "tiktoken": "^1.0.17",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=22"
  }
}
